{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@datawise/sql-editor": [
        "../sql-editor/src/index.ts"
      ],
      "@datawise/sql-editor/*": [
        "../sql-editor/src/*"
      ],
      "@sql-editor/*": [
        "../sql-editor/src/*"
      ]
    },
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "../sql-editor/src/**/*.ts",
    "../sql-editor/src/**/*.vue"
  ],
  "exclude": [
    "../sql-editor/src/__tests__/**",
    "../sql-editor/demo/**",
    "src/__tests__/**"
  ]
}

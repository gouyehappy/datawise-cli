{
  "name": "@datawise/sql-editor",
  "version": "4.0.1",
  "description": "Embeddable SQL editor for Vue 3 + Monaco — grammar-driven completion, schema-aware hints, multi-dialect parser",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "sql",
    "monaco",
    "monaco-editor",
    "vue",
    "vue3",
    "editor",
    "autocomplete",
    "intellisense",
    "database",
    "code-editor",
    "sql-editor"
  ],
  "files": [
    "src",
    "docs",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts",
    "./completion": "./src/completion/index.ts",
    "./sql-parser": "./src/sql-parser/index.ts",
    "./types": "./src/types.ts",
    "./package.json": "./package.json",
    "./*": "./src/*"
  },
  "imports": {
    "#shortcut-files": {
      "node": "./scripts/shortcut-files.node.ts",
      "default": "./src/editor/shortcut-files.vite.ts"
    },
    "#keyword-files": {
      "node": "./scripts/keyword-files.node.ts",
      "default": "./src/completion/keyword-files.vite.ts"
    },
    "#function-files": {
      "node": "./scripts/function-files.node.ts",
      "default": "./src/completion/function-files.vite.ts"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "monaco-editor": ">=0.44.0",
    "sql-formatter": ">=15.0.0",
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.7.0",
    "gifenc": "^1.0.3",
    "monaco-editor": "^0.55.1",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.43.1",
    "sql-formatter": "^15.8.1",
    "tsx": "^4.19.4",
    "typescript": "~5.7.2",
    "vite": "^7.3.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  },
  "scripts": {
    "dev": "vite",
    "build:demo": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "tsx --test src/__tests__/**/*.test.ts",
    "test:regression": "tsx --test src/__tests__/regression.test.ts",
    "test:grammar": "tsx --test src/__tests__/grammar-matrix.test.ts",
    "test:settings": "tsx --test src/__tests__/personal-*.test.ts src/__tests__/persistence.test.ts src/__tests__/shortcuts-controller.test.ts",
    "gen:snippets": "tsx scripts/generate-sql-snippets.ts",
    "gen:demo-gif": "node scripts/generate-demo-gif.mjs"
  },
  "dependencies": {
    "dt-sql-parser": "^4.5.0"
  }
}
